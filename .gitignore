# OS / Editor
.DS_Store
*~
~$*.docx
~$*.pptx
~$*.xlsx
.vscode/
.idea/

# Project-local Codex components are kept in `.codex/`.
# Keep runtime/local-only artifacts out of Git while allowing skills and
# AGENTS.md to be tracked.
.codex/logs/
.codex/tmp/
.codex/cache/
.codex/worktrees/
.codex/hookify.*.local.md

# cmux runtime workspaces are local-only. Do not track copied worker
# instruction files such as AGENTS.md or CLAUDE.md from those environments.
.cmux/
cmux/
.cmux/**/AGENTS.md
.cmux/**/CLAUDE.md
cmux/**/AGENTS.md
cmux/**/CLAUDE.md

# Python / R 환경
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.Rhistory
.Rapp.history
.Rproj.user/
.Rdata
.RData
.Renviron
.Rprofile.user

# Claude project components are tracked selectively.
.claude/settings.local.json
.claude/**/settings.local.json
.claude/plan/
.claude/worktrees/
.claude/hookify.*.local.md

